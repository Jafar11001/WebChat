@using WebChat.ViewModels.Account
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
@model RegisterViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Register</title>

    <style>
        body {
            font-family: Arial;
            background: #f4f6f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .box {
            width: 380px;
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 0 15px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        button {
            width: 100%;
            padding: 10px;
            background: #0d6efd;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background: #0b5ed7;
        }

        .text-danger {
            font-size: 12px;
            color: red;
        }

        .link {
            text-align: center;
            margin-top: 10px;
        }
    </style>
</head>

<body>

<div class="box">

    <h2>Register</h2>

    <form asp-controller="Account" asp-action="Register" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input asp-for="FullName" placeholder="Full Name" />
        <span asp-validation-for="FullName" class="text-danger"></span>

        <input asp-for="UserName" placeholder="Username" />
        <span asp-validation-for="UserName" class="text-danger"></span>

        <input asp-for="Email" placeholder="Email" />
        <span asp-validation-for="Email" class="text-danger"></span>

        <input asp-for="Password" type="password" placeholder="Password" />
        <span asp-validation-for="Password" class="text-danger"></span>

        <input asp-for="RepeatPassword" type="password" placeholder="Repeat Password" />
        <span asp-validation-for="RepeatPassword" class="text-danger"></span>

        <label>
            <input asp-for="Confirmation" type="checkbox" />
            I agree to terms
        </label>
        <span asp-validation-for="Confirmation" class="text-danger"></span>

        <button type="submit">Register</button>

    </form>

    <div class="link">
        <a asp-controller="Account" asp-action="Login">Already have an account?</a>
    </div>

</div>

</body>
</html>