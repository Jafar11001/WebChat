@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access denied</title>
    <style>
        body {
            font-family: -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
            background: #f4f6f9;
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #fff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,.12);
            text-align: center;
            max-width: 380px;
        }

        h1 { margin: 0 0 8px; font-size: 22px; color: #1c1e21; }
        p { color: #65676b; margin: 0 0 20px; }
        a { color: #1877f2; text-decoration: none; font-weight: 600; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Access denied</h1>
        <p>You don't have permission to view this page.</p>
        <a href="@Url.Action("Index", "Home")">Back to chat</a>
    </div>
</body>
</html>
