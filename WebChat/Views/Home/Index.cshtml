@{
    ViewData["Title"] = "Index";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chatter — Messaging</title>
    <link rel="stylesheet" href="~/Assets/Css/main.css">

</head>
<body>

    <!-- ╔══════════════════════════════════════════════════════════════════╗
         ║  #app  — root flex container, full viewport                     ║
         ╚══════════════════════════════════════════════════════════════════╝ -->
    <div id="app">

        <!-- ┌─────────────────────────────────────────────────────────────┐
             │  SIDEBAR                                                     │
             └─────────────────────────────────────────────────────────────┘ -->
        <aside id="sidebar">

            <!-- App menu dropdown -->
            <div id="app-menu" role="dialog" aria-modal="true" aria-label="App menu">
                <div class="menu-profile">
                    <div class="av av-xs" id="current-user-av" style="background:#E1306C;">CP</div>
                    <div>
                        <!-- data-user-id → populated from /api/me -->
                        <div class="menu-profile-name" id="current-user-name">Cristal Parker</div>
                        <div class="menu-profile-sub" id="current-user-email">cristal@example.com</div>
                    </div>
                </div>
                <ul>
                    <!-- data-action → JS routes to the right handler / page -->
                    <li class="menu-item" data-action="mentions" role="button" tabindex="0">
                        <span class="menu-ic">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6V11c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5S10.5 3.17 10.5 4v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" />
                            </svg>
                        </span>
                        <span class="menu-lbl">Mentions</span>
                        <span class="menu-badge" id="mentions-badge">1</span>
                    </li>
                    <li class="menu-item" data-action="new-dm" role="button" tabindex="0">
                        <span class="menu-ic">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 20h9" />
                                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
                            </svg>
                        </span>
                        <span class="menu-lbl">New Direct Message</span>
                    </li>
                    <li class="menu-item" data-action="new-group" role="button" tabindex="0">
                        <span class="menu-ic">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                            </svg>
                        </span>
                        <span class="menu-lbl">New Group</span>
                    </li>
                    <li class="menu-item" id="dark-item" data-action="dark-mode" role="button" tabindex="0" aria-pressed="false">
                        <span class="menu-ic">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z" />
                            </svg>
                        </span>
                        <span class="menu-lbl">Dark Mode</span>
                        <div class="toggle" id="dark-toggle" role="switch" aria-checked="false" aria-label="Toggle dark mode">
                            <div class="toggle-knob"></div>
                        </div>
                    </li>
                    <li class="menu-item" data-action="sign-out" role="button" tabindex="0">
                        <span class="menu-ic">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                <polyline points="16 17 21 12 16 7" />
                                <line x1="21" y1="12" x2="9" y2="12" />
                            </svg>
                        </span>
                        <span class="menu-lbl">Sign Out</span>
                    </li>
                </ul>
            </div><!-- /#app-menu -->
            <!-- sidebar topbar -->
            <div class="sidebar-topbar">
                <button class="btn-ham" id="menu-btn"
                        aria-expanded="false" aria-controls="app-menu" aria-label="Toggle app menu">
                    <svg width="18" height="16" viewBox="0 0 18 16" fill="none">
                        <path d="M1 2h16M1 8h16M1 14h16" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
                    </svg>
                </button>
                <div class="search-box">
                    <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                        <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.6" />
                        <path d="m10 10 2.5 2.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                    </svg>
                    <input type="search" class="search-input" id="search-input"
                           placeholder="Search" aria-label="Search conversations" autocomplete="off" />
                </div>
            </div>

            <!-- conversation list  ←  populated from /api/conversations -->
            <div class="list-section-label">Recent</div>
            <ul id="conv-list" role="listbox" aria-label="Conversations">

                <!-- data-conv-id → matches backend conversation.id -->
                <!-- data-user-id  → the other participant (DM) or null (group) -->
                <li class="conv-item"
                    data-conv-id="conv_001" data-user-id="usr_kuphal"
                    role="option" aria-selected="true" tabindex="0">
                    <div class="av-wrap">
                        <div class="av av-lg" style="background:#1877F2;">BK</div>
                        <span class="online-dot"></span>
                    </div>
                    <div class="conv-body">
                        <div class="conv-name">Bill Kuphal</div>
                        <div class="conv-preview">The weather will be perfect for th…</div>
                    </div>
                    <div class="conv-meta">
                        <span class="conv-time">9:41 AM</span>
                    </div>
                </li>

               

            </ul>
        </aside><!-- /#sidebar -->
        <!-- ┌─────────────────────────────────────────────────────────────┐
             │  CHAT PANEL                                                  │
             └─────────────────────────────────────────────────────────────┘ -->
        <section id="chat-panel" style="position:relative;">

            <!-- chat header — data-conv-id synced with active conversation -->
            <header id="chat-header" data-conv-id="conv_001">
                <div class="av-wrap">
                    <div class="av av-md" id="ch-av" style="background:#1877F2;">BK</div>
                    <span class="online-dot chat" id="ch-online-dot"></span>
                </div>
                <div class="ch-info">
                    <div class="ch-name" id="ch-name"></div>
                    <div class="ch-status">
                        <span class="ch-dot" id="ch-dot"></span>
                        <span id="ch-status"></span>
                    </div>
                </div>
                <div class="chat-actions">
                    <button class="btn-icon" aria-label="Start voice call">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.45 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-.9a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                        </svg>
                    </button>
                    <button class="btn-icon" aria-label="Start video call">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="23 7 16 12 23 17 23 7" />
                            <rect x="1" y="5" width="15" height="14" rx="2" ry="2" />
                        </svg>
                    </button>
                    <button class="btn-icon" aria-label="Search in conversation">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                    </button>
                    <button class="btn-icon" aria-label="More options">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <circle cx="12" cy="5" r="1.5" />
                            <circle cx="12" cy="12" r="1.5" />
                            <circle cx="12" cy="19" r="1.5" />
                        </svg>
                    </button>
                </div>
            </header>

            <!-- messages — data-msg-id set per message for backend sync -->
            <div id="messages" role="log" aria-live="polite"></div>
            <!-- scroll to bottom -->
            <button id="scroll-fab" aria-label="Jump to latest message">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.9"
                          stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </button>

            <!-- input bar — send -->
            <div id="input-bar">
                <!-- attach -->
                <button class="btn-attach" aria-label="Attach file or image">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" />
                    </svg>
                </button>

                <!-- text field - name="message" for forms, or wire to WS on keydown -->
                <input type="text" class="msg-field" id="msg-field"
                       name="message" placeholder="Type your message"
                       aria-label="Message input" autocomplete="off" />

                <!-- emoji -->
                <button class="btn-emoji" aria-label="Add emoji">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.5" />
                        <circle cx="7.5" cy="8.5" r="1" fill="currentColor" />
                        <circle cx="12.5" cy="8.5" r="1" fill="currentColor" />
                        <path d="M7 12.5c.667 1 5.333 1 6 0"
                              stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </button>

                <!-- send -->
                <button class="btn-send" id="send-btn" aria-label="Send message">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M14 8L2 2l3 6-3 6 12-6z" fill="white" />
                    </svg>
                </button>
            </div>

        </section><!-- /#chat-panel -->

    </div><!-- /#app -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/Assets/Js/main.js"></script>
</body>
</html>